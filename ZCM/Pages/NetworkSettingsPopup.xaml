<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="ZCM.Pages.NetworkSettingsPopup"
    BackgroundColor="#80000000">

    <Grid>

        <!-- backdrop -->
        <BoxView BackgroundColor="Transparent">
            <BoxView.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnBackdropTapped"/>
            </BoxView.GestureRecognizers>
        </BoxView>

        <Frame WidthRequest="420"
               Padding="24"
               CornerRadius="18"
               BackgroundColor="#1F1F1F"
               HorizontalOptions="Center"
               VerticalOptions="Center">

            <VerticalStackLayout Spacing="16">

                <Label Text="Network Settings"
                       FontSize="20"
                       FontAttributes="Bold"
                       TextColor="White"/>

                <VerticalStackLayout Spacing="6">

                    <Label Text="Discovery Port"
                           TextColor="#CCCCCC"/>

                    <Entry Text="{Binding DiscoveryPort}"
                           Keyboard="Numeric"
                           BackgroundColor="#333333"
                           TextColor="White"/>

                </VerticalStackLayout>

                <VerticalStackLayout Spacing="6">

                    <Label Text="Multicast Address"
                           TextColor="#CCCCCC"/>

                    <Entry Text="{Binding MulticastAddress}"
                           BackgroundColor="#333333"
                           TextColor="White"/>

                </VerticalStackLayout>

                <VerticalStackLayout Spacing="6">

                    <Label Text="Discovery Timeout (ms)"
                           TextColor="#CCCCCC"/>

                    <Entry Text="{Binding DiscoveryTimeout}"
                           Keyboard="Numeric"
                           BackgroundColor="#333333"
                           TextColor="White"/>

                </VerticalStackLayout>

                <Button
                    Text="Save"
                    Clicked="OnSaveClicked"
                    BackgroundColor="#1E88E5"
                    TextColor="White"
                    CornerRadius="12"/>

            </VerticalStackLayout>

        </Frame>

    </Grid>
</ContentPage>