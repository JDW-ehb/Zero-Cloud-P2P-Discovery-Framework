<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="ZCM.Pages.SettingsPage"
    BackgroundColor="#80000000"
    Padding="0">

    <Grid>
        <BoxView BackgroundColor="Transparent">
            <BoxView.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnBackdropTapped"/>
            </BoxView.GestureRecognizers>
        </BoxView>

        <Frame WidthRequest="600"
               Padding="24"
               CornerRadius="18"
               BackgroundColor="#1F1F1F"
               HasShadow="True"
               HorizontalOptions="Center"
               VerticalOptions="Center">

            <ScrollView>
                <VerticalStackLayout Spacing="14">

                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="Settings"
                               FontSize="20"
                               FontAttributes="Bold"
                               TextColor="White"/>

                        <Button Grid.Column="1"
                                Text="✕"
                                Clicked="OnCloseClicked"
                                BackgroundColor="#2A2A2A"
                                TextColor="White"
                                CornerRadius="10"
                                Padding="10,6"/>
                    </Grid>

                    <!-- Core Settings -->

                    <Label Text="Peer Name" TextColor="White"/>
                    <Entry Text="{Binding PeerName}" TextColor="White"/>

                    <Label Text="Discovery Port" TextColor="White"/>
                    <Entry Text="{Binding DiscoveryPort}" Keyboard="Numeric" TextColor="White"/>

                    <Label Text="Multicast Address" TextColor="White"/>
                    <Entry Text="{Binding MulticastAddress}" TextColor="White"/>

                    <Label Text="Discovery Timeout (ms)" TextColor="White"/>
                    <Entry Text="{Binding DiscoveryTimeoutMS}" Keyboard="Numeric" TextColor="White"/>

                    <!-- Management Buttons -->

                    <Button Text="Manage Groups (Trust)…"
                            Clicked="GroupsButton_Clicked"
                            BackgroundColor="#2A2A2A"
                            TextColor="White"
                            CornerRadius="12"/>

                    <Button Text="Manage Announced Services…"
                            Clicked="ServicesButton_Clicked"
                            BackgroundColor="#2A2A2A"
                            TextColor="White"
                            CornerRadius="12"/>

                    <Button Text="Save Settings"
                            Clicked="SaveButton_Clicked"
                            TextColor="White"
                            BackgroundColor="#007ACC"/>

                </VerticalStackLayout>
            </ScrollView>

        </Frame>
    </Grid>
</ContentPage>