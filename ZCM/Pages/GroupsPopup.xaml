<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="ZCM.Pages.GroupsPopup"
    BackgroundColor="#80000000">

    <Grid>

        <!-- Backdrop -->
        <BoxView BackgroundColor="Transparent">
            <BoxView.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnBackdropTapped"/>
            </BoxView.GestureRecognizers>
        </BoxView>

        <!-- Popup -->
        <Frame WidthRequest="575"
               MaximumHeightRequest="650"
               Padding="20"
               CornerRadius="18"
               BackgroundColor="#1F1F1F"
               HasShadow="False"
               HorizontalOptions="Center"
               VerticalOptions="Center">

            <VerticalStackLayout Spacing="14">

                <!-- Header -->
                <Grid ColumnDefinitions="*,Auto">
                    <Label Text="Groups (Trust)"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="White"/>

                    <Button Grid.Column="1"
                            Text="✕"
                            Clicked="OnCloseClicked"
                            BackgroundColor="#2A2A2A"
                            TextColor="White"
                            CornerRadius="10"
                            WidthRequest="36"
                            HeightRequest="36"/>
                </Grid>

                <!-- Description -->
                <Label Text="Enabled groups are trusted. Peers sharing at least one enabled group may communicate."
                       TextColor="#AAAAAA"
                       FontSize="12" />

                <!-- Groups List -->
                <Grid RowDefinitions="*"
                      HeightRequest="400">

                    <CollectionView ItemsSource="{Binding Groups}"
                                    SelectionMode="None">

                        <CollectionView.ItemTemplate>
                            <DataTemplate>

                                <Frame Padding="16"
                                       CornerRadius="16"
                                       BackgroundColor="#2A2A2A"
                                       HasShadow="False">

                                    <VerticalStackLayout Spacing="12">

                                        <!-- HEADER ROW -->
                                        <Grid ColumnSpacing="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <!-- Group Name -->
                                            <Entry Grid.Column="0"
                                                   Text="{Binding Name}"
                                                   TextColor="White"
                                                   Placeholder="Group Name"
                                                   BackgroundColor="#333333"
                                                   HeightRequest="36"
                                                   CornerRadius="8"
                                                   HorizontalOptions="Fill"
                                                   MinimumWidthRequest="140"/>

                                            <!-- Copy -->
                                            <Button Grid.Column="1"
                                                    Text="Copy"
                                                    Clicked="OnCopySecretClicked"
                                                    BackgroundColor="#333333"
                                                    TextColor="White"
                                                    CornerRadius="8"
                                                    HeightRequest="36"
                                                    Padding="12,0"/>

                                            <!-- Regenerate -->
                                            <Button Grid.Column="2"
                                                    Text="Regen"
                                                    Clicked="OnRegenerateSecretClicked"
                                                    BackgroundColor="#333333"
                                                    TextColor="White"
                                                    CornerRadius="8"
                                                    HeightRequest="36"
                                                    Padding="12,0"/>

                                            <!-- Enabled -->
                                            <Label Grid.Column="3"
                                                   Text="Enabled"
                                                   VerticalOptions="Center"
                                                   TextColor="#CCCCCC"
                                                   FontSize="12"/>

                                            <Switch Grid.Column="4"
                                                    IsToggled="{Binding IsEnabled}"
                                                    VerticalOptions="Center"/>

                                            <!-- DELETE GROUP -->
                                            <Button Grid.Column="5"
                                                    Text="✕"
                                                    Clicked="OnDeleteGroupClicked"
                                                    BackgroundColor="Transparent"
                                                    TextColor="#AAAAAA"
                                                    FontSize="18"
                                                    WidthRequest="36"
                                                    HeightRequest="36"/>
                                        </Grid>

                                        <!-- SECRET ROW -->
                                        <Grid ColumnDefinitions="*,Auto"
                                              ColumnSpacing="8">

                                            <Entry Grid.Column="0"
                                                   Text="{Binding SecretHex}"
                                                   IsPassword="True"
                                                   TextColor="White"
                                                   Placeholder="Group Secret (hex)"
                                                   BackgroundColor="#333333"
                                                   HeightRequest="36"
                                                   HorizontalOptions="Fill"
                                                   FontFamily="Consolas"
                                                   FontSize="12"
                                                   x:Name="SecretEntry"/>

                                            <Button Grid.Column="1"
                                                    Text="Show"
                                                    Clicked="OnToggleSecretClicked"
                                                    BackgroundColor="#333333"
                                                    TextColor="White"
                                                    CornerRadius="8"
                                                    HeightRequest="36"
                                                    Padding="12,0"/>
                                        </Grid>

                                    </VerticalStackLayout>

                                </Frame>

                            </DataTemplate>
                        </CollectionView.ItemTemplate>

                    </CollectionView>

                </Grid>

                <!-- Bottom Buttons -->
                <Grid ColumnDefinitions="Auto,*,Auto"
                      ColumnSpacing="12">

                    <Button Grid.Column="0"
                            Text="Back"
                            Clicked="OnBackClicked"
                            BackgroundColor="#B85C5C"
                            TextColor="White"
                            CornerRadius="12"
                            Padding="18,8"/>

                    <Button Grid.Column="1"
                            Text="Add Group +"
                            Clicked="OnAddGroupClicked"
                            BackgroundColor="#4A90C2"
                            TextColor="White"
                            CornerRadius="12"
                            HeightRequest="42"
                            HorizontalOptions="Fill"/>

                    <Button Grid.Column="2"
                            Text="Save"
                            Clicked="OnSaveClicked"
                            BackgroundColor="#3FBF6B"
                            TextColor="White"
                            CornerRadius="12"
                            Padding="18,8"/>

                </Grid>

            </VerticalStackLayout>

        </Frame>

    </Grid>
</ContentPage>